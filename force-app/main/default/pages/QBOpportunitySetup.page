<script>
    function showMemberSearch(fn,ln,id)
    {
        document.getElementById('tstpopup5').style.display='';
        document.getElementById('{!$COMPONENT.fnSearch}').value=fn;
        document.getElementById('{!$COMPONENT.lnSearch}').value=ln;
        document.getElementById('{!$COMPONENT.TorcmemberidToUpdate}').value=id;
    }
    function isVendorMapPeffect()
    {
        if(document.getElementById("{!$Component.QBvendoridToUpdate}").value=='')
        {
            alert('Please select vendor first.');
            return false;
        }
        showDisable();
        return true;
    }
    function hidememberSerach()
    {
        document.getElementById('tstpopup5').style.display='none';
    }
</script>

