<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>V1. Fire a platform event for RIG. Applicable only for non change requests type of Placements. Placements must be for US Opco with Peoplesoft ID = Blank</description>
    <environments>Default</environments>
    <formulas>
        <description>Simple JSON Representation for Placement containing Id and Name only.</description>
        <name>partialJSON</name>
        <dataType>String</dataType>
        <expression>&quot;{ &quot; &amp; 
&quot;\&quot;Id\&quot;: \&quot;&quot; &amp; {!$Record.Id} &amp; &quot;\&quot;, &quot; &amp;
&quot;\&quot;Name\&quot;: \&quot;&quot; &amp; {!$Record.Name} &amp; &quot;\&quot;&quot; &amp;
&quot;}&quot;</expression>
    </formulas>
    <formulas>
        <name>user18Digit</name>
        <dataType>String</dataType>
        <expression>CASESAFEID({!$User.Id})</expression>
    </formulas>
    <interviewLabel>Placement: RIG Data Event - Update {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Placement:RIG Data Event - Update</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <description>Create RD Event Record</description>
        <name>Create_Event_Record</name>
        <label>Create RD Event Record</label>
        <locationX>308</locationX>
        <locationY>276</locationY>
        <inputAssignments>
            <field>Change_Type__c</field>
            <value>
                <stringValue>Update</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Changed_By__c</field>
            <value>
                <elementReference>user18Digit</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Entity__c</field>
            <value>
                <stringValue>Placement</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Fields__c</field>
            <value>
                <elementReference>partialJSON</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Record_Id__c</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Reference_ID__c</field>
            <value>
                <elementReference>$Record.Name</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Source__c</field>
            <value>
                <elementReference>$Flow.InterviewGuid</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Timestamp__c</field>
            <value>
                <elementReference>$Flow.CurrentDateTime</elementReference>
            </value>
        </inputAssignments>
        <object>RD_ChangeEvent__e</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterFormula>AND(
ISCHANGED({!$Record.LastModifiedDate}),  
TEXT({!$Record.User_Opco__c}) = &quot;US&quot;,
  ISBLANK({!$Record.PeopleSoft_ID__c}),
  {!$Record.RecordType.Name} &lt;&gt; &quot;Change Request&quot;,
  {!$Record.RecordType.Name} &lt;&gt; &quot;Change Request Permanent&quot;,
   {!$Setup.Active_Trigger_Flow_VR__c.Placement_Flow__c} = TRUE
)</filterFormula>
        <object>TR1__Closing_Report__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <scheduledPaths>
            <connector>
                <targetReference>Create_Event_Record</targetReference>
            </connector>
            <pathType>AsyncAfterCommit</pathType>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
