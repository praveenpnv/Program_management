@isTest
private class InsertSkillsTest {

    @isTest
    static void testProcessSkills() {
        // Step 1: Create test data
        // Create a Contact record to assign to the Contact_Candidate__c field
        Contact testContact = new Contact(LastName = 'Test Contact');
        insert testContact;

        List<ATSExtractedCandidateSkill__c> testSkills = new List<ATSExtractedCandidateSkill__c>();
        for (Integer i = 0; i < 5; i++) {
            testSkills.add(new ATSExtractedCandidateSkill__c(
                // Assign the Contact record to the required Contact_Candidate__c field
                Contact_Candidate__c = testContact.Id
            ));
        }
        
        // Step 2: Insert the first two skills to simulate existing records for duplicates
        insert testSkills[0]; // Insert the first skill
        insert testSkills[1]; // Insert the second skill

        // Step 3: Create an instance of the Parameter class to pass into the invocable method
        InsertSkills.Parameter param = new InsertSkills.Parameter();
        param.extractedSkills = testSkills;

        // Step 4: Call the processSkills method with the parameter
        Test.startTest();
        InsertSkills.processSkills(new List<InsertSkills.Parameter>{param});
        Test.stopTest();

        // Step 5: Verify the insertions
        // We will query the ATSExtractedCandidateSkill__c records to check that the new skills are inserted
        List<ATSExtractedCandidateSkill__c> insertedSkills = [SELECT Name FROM ATSExtractedCandidateSkill__c];

        // Verify that only new records (Skill 2, Skill 3, Skill 4) were inserted (since Skill 0 and Skill 1 already existed)
        System.assertEquals(5, insertedSkills.size(), 'Five skills should be inserted.');

        // Optionally, you can also verify specific fields of the inserted records if needed
        Set<String> insertedNames = new Set<String>();
        for (ATSExtractedCandidateSkill__c skill : insertedSkills) {
            insertedNames.add(skill.Name);
        }

        // In this case, we can't verify specific names unless you know how they were generated
        // If the Name is auto-generated by Salesforce, you cannot check its value directly in a test
        System.assert(insertedNames.size() == 5, 'Five unique skills should be inserted');
    }

    @isTest
    static void testProcessSkillsWithErrorHandling() {
        // Step 1: Create test data with an invalid skill (to simulate an error)
        // Create a Contact record for the required field
        Contact testContact = new Contact(LastName = 'Test Contact');
        insert testContact;

        List<ATSExtractedCandidateSkill__c> testSkills = new List<ATSExtractedCandidateSkill__c>();
        testSkills.add(new ATSExtractedCandidateSkill__c(
            // Simulating an error by setting Name to null (or missing required fields)
            // This will cause a validation error
            Contact_Candidate__c = testContact.Id  // Ensure Contact_Candidate__c is set
        ));

        // Step 2: Create an instance of the Parameter class to pass into the invocable method
        InsertSkills.Parameter param = new InsertSkills.Parameter();
        param.extractedSkills = testSkills;

        // Step 3: Call the processSkills method and simulate an error on insert
        Test.startTest();
        InsertSkills.processSkills(new List<InsertSkills.Parameter>{param});
        Test.stopTest();

        // Step 4: Query the records to verify that none were inserted due to the error
        List<ATSExtractedCandidateSkill__c> insertedSkills = [SELECT Name FROM ATSExtractedCandidateSkill__c WHERE Name = null];

        System.assertEquals(0, insertedSkills.size(), 'No invalid skills should be inserted due to errors.');
    }
}